NODE_ENV=production
PORT=8000

# 32文字以上のランダム値を設定してください。例: openssl rand -base64 48
CARE_ROUTE_DATA_KEY=replace-with-strong-random-secret-at-least-32-chars

# 本番PINは6文字以上にしてください。必要なユーザーだけ有効化できます。
LOGIN_PINS={"shimizu":"123456","suyama":"234567","customer_demo":"345678"}

# 個別指定も可能です。LOGIN_PINS と併用した場合はこちらが優先されます。
# PIN_SHIMIZU=123456
# PIN_SUYAMA=234567
# PIN_CUSTOMER_DEMO=345678

SESSION_TTL_HOURS=12
LOGIN_RATE_LIMIT_MAX=8
LOGIN_RATE_LIMIT_WINDOW_MS=600000

CARE_ROUTE_DELETED_CUSTOMER_DAYS=30
CARE_ROUTE_ROUTE_DRAFT_DAYS=90
CARE_ROUTE_AUDIT_DAYS=730
